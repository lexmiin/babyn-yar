---
import type { ContentSchema, Metadata } from '@babyn-yar/schema'
import { ContentAPI } from '@babyn-yar/api-utils'
import CMSList from '@/components/CMSList.astro'

export const prerender = false

const page = Number(Astro.url.searchParams.get('page') || '1')
const response = await ContentAPI.list<{
  concepts: ContentSchema.Content[]
  metadata: Metadata
}>({ slug: 'development-concepts', filters: { page, lang: 'ua' } })
---

<CMSList
  title="Концепція розвитку"
  description="Концепція розвитку Державного історико-меморіального заповідника „Бабин Яр”"
  slug="/development-concept"
  list={response.concepts}
  metadata={response.metadata}
/>
