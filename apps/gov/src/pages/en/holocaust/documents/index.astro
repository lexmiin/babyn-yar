---
import type { ContentSchema, Metadata } from '@babyn-yar/schema'
import { ContentAPI } from '@babyn-yar/api-utils'
import CMSList from '@/components/CMSList.astro'

export const prerender = false

const page = Number(Astro.url.searchParams.get('page') || '1')
const response = await ContentAPI.list<{
  documents: ContentSchema.Content[]
  metadata: Metadata
}>({ slug: 'holocaust-documents', filters: { page, lang: 'en' } })
---

<CMSList
  title="Holocaust Documents"
  description="Holocaust Documents"
  slug="en/holocaust/documents"
  list={response.documents}
  metadata={response.metadata}
/>
